# iGosa — Environment Configuration
# Copy to .env and fill in values

# ── AI Provider (pick one) ──────────────────────────
# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
# Anthropic (alternative)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Evolution API ───────────────────────────────────
# Your Evolution API instance URL
EVOLUTION_API_URL=https://your-evolution-api.onrender.com
EVOLUTION_API_KEY=your-evolution-api-key-here
EVOLUTION_INSTANCE_NAME=igosa

# Webhook secret to verify incoming webhooks from Evolution
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Database ────────────────────────────────────────
# SQLite (free Render tier)
DATABASE_URL=sqlite+aiosqlite:///./igosa.db
# When ready for PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/igosa

# Redis (optional, for Celery tasks — skip on free tier)
# REDIS_URL=redis://localhost:6379/0

# ── Application ─────────────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=8000

# ── South Africa Specific ───────────────────────────
DEFAULT_COUNTRY_CODE=27
DEFAULT_CITY=Johannesburg
